# HMS API environment (copy to server ~/stacks/hms.env, chmod 600)
HOST=0.0.0.0
PORT=3000
APP_VERSION=1.3.0

DB_HOST=postgres
DB_PORT=5432
DB_NAME=hms
DB_USER=hms_user
DB_PASS=change-me

JWT_SECRET=change-me-long-random
UPLOAD_DIR=/data/uploads

# Public origin of the app (used for push VAPID subject + telegram link buttons)
PUBLIC_URL=

# Telegram parent notifications (optional)
TELEGRAM_BOT_TOKEN=
# secret for webhook callbacks (inline approve buttons); set the webhook with setWebhook
TELEGRAM_WEBHOOK_SECRET=

# Ops bridge (remote notify + decision channel). OPS_TOKEN authorizes /api/ops/*.
# OPS_CHAT_ID is the owner's chat with the bot (target for ops messages).
OPS_TOKEN=
OPS_CHAT_ID=
