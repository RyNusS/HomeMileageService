# HMS API environment (copy to server ~/stacks/hms.env, chmod 600)
HOST=0.0.0.0
PORT=3000
APP_VERSION=1.2.0

DB_HOST=postgres
DB_PORT=5432
DB_NAME=hms
DB_USER=hms_user
DB_PASS=change-me

JWT_SECRET=change-me-long-random
UPLOAD_DIR=/data/uploads

# Telegram parent notifications (optional)
TELEGRAM_BOT_TOKEN=
